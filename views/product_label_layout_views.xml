<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Archivamos la vista original de stock_voucher para evitar duplicados,
         porque hereda de product.product_label_layout_form y no siempre se
         aplica correctamente sobre la vista primary del picking. -->
    <record id="stock_voucher.view_picking_zpl_nuevo" model="ir.ui.view">
        <field name="active">False</field>
    </record>

    <!-- Nueva vista que hereda directamente de la vista primary del picking.
         Usa <list> sin widget forzado para asegurar que sea editable inline. -->
    <record id="view_picking_label_layout_form_picking_fix" model="ir.ui.view">
        <field name="name">product.label.layout.form.picking.fix</field>
        <field name="model">product.label.layout</field>
        <field name="inherit_id" ref="stock.product_label_layout_form_picking"/>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <xpath expr="//group" position="before">
                <group invisible="context.get('active_model') != 'stock.picking'">
                    <field name="picking_id" string="Transferencia" readonly="1" invisible="1"/>
                    <field name="line_ids" nolabel="1" colspan="2">
                        <list editable="top" create="false" delete="false">
                            <field name="move_id" column_invisible="True"/>
                            <field name="name" string="Producto"/>
                            <field name="move_quantity" string="Cantidad a imprimir"/>
                            <field name="move_uom_id" string="Unidad" readonly="1"/>
                        </list>
                    </field>
                </group>
                <div invisible="context.get('active_model') != 'stock.picking'">
                    <button name="action_print" type="object" string="Etiqueta de producto(ZPL)" class="btn btn-primary" style="font-size: 10px; margin-right: 10px;" help="Puede establecerse la cantidad de impresiones desde el asistente"/>
                </div>
                <br invisible="context.get('active_model') != 'stock.picking'"/>
            </xpath>
        </field>
    </record>

    <record id="view_product_label_layout_form_product_fix" model="ir.ui.view">
        <field name="name">product.label.layout.form.product.fix</field>
        <field name="model">product.label.layout</field>
        <field name="inherit_id" ref="product.product_label_layout_form"/>
        <field name="priority">99</field>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='custom_quantity']" position="before">
                <field name="line_product_ids" invisible="not line_product_ids" nolabel="1" colspan="2">
                    <list editable="top" create="false" delete="false">
                        <field name="product_id" readonly="1" string="Producto"/>
                        <field name="quantity" string="Cantidad a imprimir"/>
                    </list>
                </field>
            </xpath>
        </field>
    </record>
</odoo>
